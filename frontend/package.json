{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "vite:clear-cache": "bash scripts/clear-vite-cache.sh",
    "build:dev": "vite build --minify false --mode development",
    "build": "tsc && vite build --mode production",
    "preview": "vite preview",
    "test": "cross-env CI=1 NODE_OPTIONS=--max-old-space-size=6144 vitest run",
    "test:watch": "vitest",
    "test:hotkeys": "cross-env CI=1 vitest run src/__tests__ --test-timeout=5000",
    "test:hotkeys:watch": "vitest src/__tests__ --test-timeout=5000",
    "test:coverage": "cross-env CI=1 vitest run --coverage src/__tests__",
    "lint": "biome check .",
    "lint:imports": "node ./scripts/check-import-boundaries.mjs",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "dependencies": {
    "@blocknote/code-block": "^0.43.0",
    "@blocknote/core": "^0.43.0",
    "@blocknote/react": "^0.43.0",
    "@blocknote/shadcn": "^0.43.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/forms": "^0.5.10",
    "@tanstack/react-virtual": "^3.13.18",
    "@wailsio/runtime": "^3.0.0-alpha.79",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.5.9",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.16",
    "zod": "^3.25.76",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@tailwindcss/vite": "^4.1.16",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "baseline-browser-mapping": "^2.9.19",
    "cross-env": "^7.0.3",
    "jsdom": "^24.1.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "terser": "^5.44.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.12"
  }
}
