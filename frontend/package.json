{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "vite",
    "vite:clear-cache": "bash scripts/clear-vite-cache.sh",
    "build:dev": "vite build --minify false --mode development",
    "build": "tsc && vite build --mode production",
    "preview": "vite preview",
    "test": "cross-env CI=1 NODE_OPTIONS=--max-old-space-size=6144 vitest run",
    "test:watch": "vitest",
    "test:hotkeys": "cross-env CI=1 vitest run src/__tests__ --test-timeout=5000",
    "test:hotkeys:watch": "vitest src/__tests__ --test-timeout=5000",
    "test:coverage": "cross-env CI=1 vitest run --coverage src/__tests__",
    "lint": "biome check .",
    "lint:imports": "node ./scripts/check-import-boundaries.mjs",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "dependencies": {
    "@blocknote/code-block": "0.52.1",
    "@blocknote/core": "0.52.1",
    "@blocknote/react": "0.52.1",
    "@blocknote/shadcn": "0.52.1",
    "@excalidraw/excalidraw": "^0.18.1",
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource/jetbrains-mono": "^5.3.0",
    "@fontsource/outfit": "^5.3.0",
    "@radix-ui/react-checkbox": "^1.3.9",
    "@radix-ui/react-context-menu": "^2.3.5",
    "@radix-ui/react-dialog": "^1.1.21",
    "@radix-ui/react-label": "^2.1.13",
    "@radix-ui/react-select": "^2.3.5",
    "@radix-ui/react-switch": "^1.3.5",
    "@radix-ui/react-toast": "^1.2.21",
    "@radix-ui/react-tooltip": "^1.2.14",
    "@tailwindcss/forms": "^0.5.11",
    "@tanstack/react-virtual": "^3.14.8",
    "@wailsio/runtime": "^3.0.0-alpha.97",
    "autoprefixer": "^10.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "fuse.js": "^7.5.0",
    "lucide-react": "^1.26.0",
    "minisearch": "^7.2.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-resizable-panels": "^4.12.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "axe-core": "^4.12.1",
    "baseline-browser-mapping": "^2.11.1",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "patch-package": "^8.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "terser": "^5.49.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "lodash-es": "^4.18.1",
    "nanoid": "^3.3.8"
  }
}
